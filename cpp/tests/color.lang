@ "cstdio16.lang"
@ "ffi.lang"
@ "stdio.lang"

_color_io = bind_lib({
    lib : string = cstdio16.lib
    abi : string = cstdio16.abi
    functions = {
        putchar = cstdio16.functions.putchar
    }
})

_esc = () {
    _color_io.putchar(27)
}

_set_color = (code : string) {
    _esc()
    printf_s("%s", "[")
    printf_s("%s", code)
    printf_s("%s", "m")
}

_reset_color = () {
    _esc()
    printf_s("%s", "[0m")
}

print_pass = (name : string) {
    _set_color("32")
    printf_s("%s", "PASS")
    _reset_color()
    printf_s("%s", " ")
    printf_s("%s", name)
    printf_s("%s", "\n")
}

print_fail = (name : string) {
    _set_color("31")
    printf_s("%s", "FAIL")
    _reset_color()
    printf_s("%s", " ")
    printf_s("%s", name)
    printf_s("%s", "\n")
}

report_test = (name : string, ok : int) {
    ? ok == 1 { print_pass(name) } { print_fail(name) }
    ok
}
