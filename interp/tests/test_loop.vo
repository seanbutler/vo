# "tests/color.vo"

ok : int := 1

// immediate break — body never executes past \
ran : int := 0
~{ ran := 1  \ }
? ran == 1 { } { ok := 0 }

// while-style: break at top, count 1..5
i : int := 1
~{
    ? i > 5 { \ }
    i := i + 1
}
? i == 6 { } { ok := 0 }

// do-while style: body runs at least once, break at bottom
j : int := 0
~{
    j := j + 1
    ? j == 3 { \ }
}
? j == 3 { } { ok := 0 }

// until-style: break when condition becomes true
n : int := 10
~{
    ? n == 7 { \ }
    n := n - 1
}
? n == 7 { } { ok := 0 }

// mid-loop break: preamble always runs, epilogue only if not broken
preamble : int := 0
epilogue : int := 0
k : int := 0
~{
    preamble := preamble + 1
    ? k == 2 { \ }
    epilogue := epilogue + 1
    k := k + 1
}
? preamble == 3 { } { ok := 0 }   // ran 3 times before break
? epilogue == 2 { } { ok := 0 }   // epilogue skipped on final iteration

// nested loops: inner \ only breaks inner
outer_count : int := 0
inner_total : int := 0
~{
    ? outer_count == 3 { \ }
    inner : int := 0
    ~{
        ? inner == 2 { \ }
        inner_total := inner_total + 1
        inner := inner + 1
    }
    outer_count := outer_count + 1
}
? outer_count == 3  { } { ok := 0 }
? inner_total == 6  { } { ok := 0 }   // 3 outer * 2 inner

// ! logical NOT: falsy value
? !0 == 1 { } { ok := 0 }

// ! logical NOT: truthy value
? !1 == 0 { } { ok := 0 }

// double NOT restores value
? !!1 == 1 { } { ok := 0 }
? !!0 == 0 { } { ok := 0 }

// ! used as loop condition
flag : int := 0
done : int := 0
~{
    ? !done { flag := flag + 1 }
    done := 1
    ? done { \ }
}
? flag == 1 { } { ok := 0 }

loop_test_ok = ok
report_test("loop", loop_test_ok)
