# "lib/logic.vo"
# "tests/color.vo"

ok : int := 1

// not
? logic.not(0) == 1 { } { ok := 0 }
? logic.not(1) == 0 { } { ok := 0 }
? logic.not(42) == 0 { } { ok := 0 }

// and
? logic.and(0, 0) == 0 { } { ok := 0 }
? logic.and(0, 1) == 0 { } { ok := 0 }
? logic.and(1, 0) == 0 { } { ok := 0 }
? logic.and(1, 1) == 1 { } { ok := 0 }

// or
? logic.or(0, 0) == 0 { } { ok := 0 }
? logic.or(0, 1) == 1 { } { ok := 0 }
? logic.or(1, 0) == 1 { } { ok := 0 }
? logic.or(1, 1) == 1 { } { ok := 0 }

// xor
? logic.xor(0, 0) == 0 { } { ok := 0 }
? logic.xor(0, 1) == 1 { } { ok := 0 }
? logic.xor(1, 0) == 1 { } { ok := 0 }
? logic.xor(1, 1) == 0 { } { ok := 0 }

// nand
? logic.nand(0, 0) == 1 { } { ok := 0 }
? logic.nand(0, 1) == 1 { } { ok := 0 }
? logic.nand(1, 0) == 1 { } { ok := 0 }
? logic.nand(1, 1) == 0 { } { ok := 0 }

// nor
? logic.nor(0, 0) == 1 { } { ok := 0 }
? logic.nor(0, 1) == 0 { } { ok := 0 }
? logic.nor(1, 0) == 0 { } { ok := 0 }
? logic.nor(1, 1) == 0 { } { ok := 0 }

// xnor
? logic.xnor(0, 0) == 1 { } { ok := 0 }
? logic.xnor(0, 1) == 0 { } { ok := 0 }
? logic.xnor(1, 0) == 0 { } { ok := 0 }
? logic.xnor(1, 1) == 1 { } { ok := 0 }

// derived: de morgan — not(and(a,b)) == or(not(a),not(b))
? logic.nand(1, 0) == logic.or(logic.not(1), logic.not(0)) { } { ok := 0 }
? logic.nand(1, 1) == logic.or(logic.not(1), logic.not(1)) { } { ok := 0 }

// derived: xor from nand chain — xor(a,b) == nand(nand(a,nand(a,b)),nand(b,nand(a,b)))
xor_from_nand = @(a : int, b : int) {
    n  : int = logic.nand(a, b)
    logic.nand(logic.nand(a, n), logic.nand(b, n))
}
? xor_from_nand(0, 0) == logic.xor(0, 0) { } { ok := 0 }
? xor_from_nand(0, 1) == logic.xor(0, 1) { } { ok := 0 }
? xor_from_nand(1, 0) == logic.xor(1, 0) { } { ok := 0 }
? xor_from_nand(1, 1) == logic.xor(1, 1) { } { ok := 0 }

logic_test_ok = ok
report_test("logic", logic_test_ok)
