@ "tests/color.vo"

ok : int := 1

// emoji as a plain identifier
🐺 = "wolf"
? 🐺 == "wolf" { } { ok := 0 }

// emoji as a mutable variable
🔢 : int := 0
🔢 := 🔢 + 1
? 🔢 == 1 { } { ok := 0 }

// extended-ASCII (precomposed)
café : int := 42
? café == 42 { } { ok := 0 }

// emoji hash key via dynamic member access
🗺 = { x : int = 10  y : int = 20 }
? 🗺.x + 🗺.y == 30 { } { ok := 0 }

// emoji callable
➕ = (a : int, b : int) { a + b }
? ➕(3, 4) == 7 { } { ok := 0 }

// emoji identifier in arithmetic
🅰 : int := 5
🅱 : int := 3
? 🅰 * 🅱 == 15 { } { ok := 0 }

// two distinct emoji identifiers with the same visual weight
α = 1
β = 2
? α + β == 3 { } { ok := 0 }

unicode_test_ok = ok
report_test("unicode", unicode_test_ok)
