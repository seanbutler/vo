@ "tests/color.vo"
@ "lib/loops.vo"

ok : int := 1

// emoji as a plain identifier
рџђє = "wolf"
? рџђє == "wolf" { } { ok := 0 }

// emoji as a mutable variable
рџ”ў : int := 0
рџ”ў := рџ”ў + 1
? рџ”ў == 1 { } { ok := 0 }

// extended-ASCII (precomposed)
cafГ© : int := 42
? cafГ© == 42 { } { ok := 0 }

// emoji hash key via dynamic member access
рџ—є = { x : int = 10  y : int = 20 }
? рџ—є.x + рџ—є.y == 30 { } { ok := 0 }


// emoji callable
вћ• = (a : int, b : int) { a + b }
? вћ•(3, 4) == 7 { } { ok := 0 }

// emoji identifier in arithmetic
рџ…° : int := 5
рџ…± : int := 3
? рџ…° * рџ…± == 15 { } { ok := 0 }

// two distinct emoji identifiers with the same visual weight
О± = 1
ОІ = 2
? О± + ОІ == 3 { } { ok := 0 }

// mixed: unicode leading, ASCII trailing
рџђє_count : int := 3
? рџђє_count == 3 { } { ok := 0 }

// mixed: ASCII leading, unicode trailing
speedрџљЂ : int := 99
? speedрџљЂ == 99 { } { ok := 0 }

// mixed: ASCII, unicode, ASCII interleaved
xрџ”Ґy : int := 7
? xрџ”Ґy == 7 { } { ok := 0 }


// mixed: extended-ASCII blended with ASCII
naГЇve : int := 1
? naГЇve == 1 { } { ok := 0 }

// mixed identifier used as callable param and in arithmetic
doubleрџ”ў = (nрџ”ў : int) { nрџ”ў * 2 }
? doubleрџ”ў(6) == 12 { } { ok := 0 }

// mixed identifier as hash slot name, accessed via static member
stats = { maxрџ”ў : int = 100  minрџ”ў : int = 0 }
? stats.maxрџ”ў - stats.minрџ”ў == 100 { } { ok := 0 }

// рџ”Ѓ as an alias for loops.while (U+1F501)
рџ”Ѓ = loops.while

loop_count : int := 0
рџ”Ѓ(
    () { loop_count < 5 },
    () { loop_count := loop_count + 1 }
)
? loop_count == 5 { } { ok := 0 }

unicode_test_ok = ok
report_test("unicode", unicode_test_ok)
