@ "lib/stdlib.vo"
@ "tests/color.vo"

ok : int <- 1

src = { a : int = 1  b : int = 2 }
cl = clone(src)
? cl.a == 1 { } { ok <- 0 }
? cl.b == 2 { } { ok <- 0 }

wo = without(src, "a")
? has(wo, "a") == 0 { } { ok <- 0 }

rn = rename(src, "a", "x")
? has(rn, "x") == 1 { } { ok <- 0 }

mg = merge(src, { c : int = 3  a : int = 9 })
? mg.a == 9 { } { ok <- 0 }
? size(src) == 2 { } { ok <- 0 }

flt = filter_map(mg, (k, v) { v > 2 })
? has(flt, "b") == 0 { } { ok <- 0 }
? has(flt, "a") == 1 { } { ok <- 0 }

mv = map_values(src, (v) { v * 2 })
? mv.a == 2 { } { ok <- 0 }

? almost_equal(0.1 + 0.2, 0.3, 0.000001) == 1 { } { ok <- 0 }

stdlib_test_ok = ok
report_test("stdlib", stdlib_test_ok)
