logic = {
    not  = @(a)    { ? a { 0 } { 1 } }
    and  = @(a, b) { ? a { b } { 0 } }
    or   = @(a, b) { ? a { 1 } { b } }
    xor  = @(a, b) { ? a { ? b { 0 } { 1 } } { ? b { 1 } { 0 } } }
    nand = @(a, b) { ? a { ? b { 0 } { 1 } } { 1 } }
    nor  = @(a, b) { ? a { 0 } { ? b { 0 } { 1 } } }
    xnor = @(a, b) { ? a { b } { ? b { 0 } { 1 } } }
}
